---
// ProjectsTab.astro — Projects tab content
import { projects } from '../../data/portfolio';

const enterpriseProjects = projects.filter(p => p.type === 'enterprise');
const personalProjects = projects.filter(p => p.type === 'personal');
---

<section id="content-projects" class="space-y-8 hidden">

  <!-- ── Personal Projects ── -->
  <div>
    <h2 class="text-lg font-bold mb-4" style="font-family: var(--font-headline);">Proyectos Personales</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      {personalProjects.map((project) => (
        <article class="card card-lift p-5 flex flex-col relative overflow-hidden">
          {project.featured && (
            <div class="absolute top-3 right-3 z-10">
              <span class="badge-gold">★ Destacado</span>
            </div>
          )}

          <!-- Image Section for Personal Projects -->
          {project.image ? (
            <div class="relative w-full aspect-video rounded-xl overflow-hidden mb-4 border" style="border-color: rgba(255,255,255,0.05); background: var(--color-night);">
              <img src={project.image} alt={project.title} class="w-full h-full object-cover" loading="lazy" />
              <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
            </div>
          ) : (
            <!-- Fallback Icon if no image -->
            <div class="w-10 h-10 rounded-xl flex items-center justify-center mb-4" style="background: var(--color-gold-soft); border: 1px solid rgba(242,184,0,0.15);">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-gold)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
            </div>
          )}

          <h3 class="text-sm font-bold mb-1.5" style="font-family: var(--font-headline); color: var(--color-white);">
            {project.title}
          </h3>
          <p class="text-xs leading-relaxed mb-4 flex-grow" style="color: var(--color-muted);">
            {project.description}
          </p>

          <!-- Stack tags -->
          <div class="flex flex-wrap gap-1.5 mb-4 mt-auto">
            {project.stack.map((tech) => (
              <span class="skill-tag" style="font-size: 0.6875rem; padding: 0.25rem 0.5rem;">
                {tech}
              </span>
            ))}
          </div>

          <!-- Links -->
          <div class="flex gap-3 mt-2 border-t pt-4" style="border-color: rgba(255,255,255,0.05);">
            {project.link && (
              <a href={project.link} target="_blank" rel="noopener noreferrer" class="text-xs font-medium flex items-center gap-1.5 hover:text-white transition-colors" style="color: var(--color-muted);">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                Web
              </a>
            )}
            {project.apk && (
              <a href={project.apk} download class="text-xs font-medium flex items-center gap-1.5 hover:text-white transition-colors" style="color: var(--color-gold);">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                APK
              </a>
            )}
            {project.github && (
              <a href={project.github} target="_blank" rel="noopener noreferrer" class="text-xs font-medium flex items-center gap-1.5 hover:text-white transition-colors" style="color: var(--color-muted);">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
                GitHub
              </a>
            )}
          </div>
        </article>
      ))}
    </div>
  </div>
  
  <!-- ── Enterprise Projects ── -->
  <div>
    <h2 class="text-lg font-bold mb-4" style="font-family: var(--font-headline);">Proyectos Empresariales</h2>
    <div class="space-y-4">
      {enterpriseProjects.map((project) => (
        <article class="card card-lift p-0 overflow-hidden flex flex-col sm:flex-row">
          <!-- Image Section -->
          <div class="sm:w-2/5 flex-shrink-0 relative overflow-hidden bg-black/20 hidden sm:block border-b sm:border-b-0 sm:border-r" style="border-color: var(--color-night-border);">
             <img src={project.image} alt={project.title} class="w-full h-full object-cover sm:absolute inset-0" loading="lazy" />
          </div>
          
          <!-- Image for Mobile -->
          <div class="w-full aspect-video relative overflow-hidden sm:hidden border-b" style="border-color: var(--color-night-border);">
             <img src={project.image} alt={project.title} class="w-full h-full object-cover absolute inset-0" loading="lazy" />
          </div>
          
          <!-- Content Section -->
          <div class="p-5 flex flex-col flex-grow">
            <h3 class="text-sm font-bold mb-2" style="font-family: var(--font-headline); color: var(--color-white);">
              {project.title}
            </h3>
            <p class="text-xs leading-relaxed mb-4 flex-grow" style="color: var(--color-muted);">
              {project.description}
            </p>

            <!-- Stack tags -->
            <div class="flex flex-wrap gap-1.5 mb-4 mt-auto">
              {project.stack.map((tech) => (
                <span class="skill-tag" style="font-size: 0.6875rem; padding: 0.25rem 0.5rem; background: var(--color-night); border: 1px solid var(--color-night-border);">
                  {tech}
                </span>
              ))}
            </div>

            <!-- Links -->
            <div class="flex gap-4 mt-2 border-t pt-4" style="border-color: rgba(255,255,255,0.05);">
              {project.link && (
                <a href={project.link} target="_blank" rel="noopener noreferrer" class="text-xs font-medium flex items-center gap-1.5 hover:text-white transition-colors" style="color: var(--color-muted);">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                  Web Demo
                </a>
              )}
              {project.apk && (
                <a href={project.apk} download class="text-xs font-medium flex items-center gap-1.5 hover:text-white transition-colors" style="color: var(--color-gold);">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                  APK Download
                </a>
              )}
              {project.github && (
                <a href={project.github} target="_blank" rel="noopener noreferrer" class="text-xs font-medium flex items-center gap-1.5 hover:text-white transition-colors" style="color: var(--color-muted);">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
                  GitHub
                </a>
              )}
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
