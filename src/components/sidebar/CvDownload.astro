---
// CvDownload.astro — Small card with CV download button
import { profile } from '../../data/portfolio';
---

<div class="card p-5">
  <h2 class="section-label mb-4">Curriculum</h2>
  <div class="flex items-center justify-between">
    <div class="flex items-center gap-3">
      <div class="social-icon" style="width: 2rem; height: 2rem;">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
      </div>
      <div>
        <p class="text-sm font-medium" style="color: var(--color-white);">{profile.name}</p>
        <p class="text-xs" style="color: var(--color-muted-dim);">PDF</p>
      </div>
    </div>
    <a
      href={profile.cvPath}
      download
      class="w-9 h-9 rounded-xl flex items-center justify-center transition-all duration-200"
      style="background: var(--color-gold); color: var(--color-night);"
      aria-label="Descargar CV"
      onmouseover="this.style.boxShadow='0 0 15px rgba(242,184,0,0.3)'"
      onmouseout="this.style.boxShadow='none'"
    >
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
    </a>
  </div>
</div>
